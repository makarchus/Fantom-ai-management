# Meeting Intelligence — environment template
# Copy to .env and fill in your values:
#   cp sample.env .env

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
PGHOST=localhost
PGPORT=5432
PGDATABASE=meeting_intelligence
PGUSER=postgres
PGPASSWORD=your_password_here

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Session signing secret (use a long random string in production)
SESSION_SECRET=change-me-to-a-long-random-string

# -----------------------------------------------------------------------------
# Google OAuth (required for login)
# Create credentials: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3001/api/auth/google/callback
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# -----------------------------------------------------------------------------
# Fathom API (optional at startup — can also be set per-user in Settings)
# Generate in Fathom → Settings → API Access
# -----------------------------------------------------------------------------
FATHOM_API_KEY=

# -----------------------------------------------------------------------------
# Anthropic (optional — AI categorization & action-item fallback)
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...
